# Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub (add to .gitignore)

# ===== DATABASE =====
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
# Local: postgresql://postgres:password@localhost:5432/military_english
# Production (Railway): postgresql://user:pass@abc.railway.app:5432/db_name
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/military_english

# ===== FLASK CONFIGURATION =====
# Environment: development, staging, or production
FLASK_ENV=production

# Secret key for session management
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=your_generated_secret_key_here_32_characters

# Debug mode (NEVER True in production)
DEBUG=False

# ===== SERVER CONFIGURATION =====
# Number of gunicorn workers (production servers)
# Formula: (2 × CPU cores) + 1
# Example: 4 cores = 9 workers
API_WORKERS=4

# Server host (0.0.0.0 allows external access)
API_HOST=0.0.0.0

# Server port
API_PORT=5000

# ===== CORS CONFIGURATION =====
# Comma-separated list of allowed origins
# Development: http://localhost:3000,http://localhost:5000
# Production: https://your-domain.com,https://www.your-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ===== DATABASE POOL CONFIGURATION =====
# Connection pool settings (advanced)
DB_POOL_SIZE=20          # Number of persistent connections
DB_MAX_OVERFLOW=10       # Additional overflow connections
DB_POOL_TIMEOUT=30       # Timeout in seconds
DB_ECHO=False            # Log all SQL queries (for debugging)

# ===== LOGGING CONFIGURATION =====
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file location (optional)
LOG_FILE=/var/log/pronunciation-trainer/api.log

# ===== SENTRY ERROR TRACKING (OPTIONAL) =====
# For error tracking and monitoring
# Get from: https://sentry.io
SENTRY_DSN=

# ===== EMAIL CONFIGURATION (OPTIONAL) =====
# For sending emails (welcome, password reset, etc.)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password  # Generate app-specific password
MAIL_USE_TLS=True
MAIL_DEFAULT_SENDER=noreply@your-domain.com

# ===== AWS S3 CONFIGURATION (OPTIONAL) =====
# For storing audio files, user recordings, etc.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=pronunciation-trainer-uploads
AWS_S3_REGION=us-east-1

# ===== REDIS CONFIGURATION (OPTIONAL) =====
# For caching and rate limiting
REDIS_URL=redis://localhost:6379/0

# ===== FEATURE FLAGS =====
# Enable/disable features in production
ENABLE_AUDIO_RECORDING=True
ENABLE_USER_LEADERBOARD=False
ENABLE_PREMIUM_FEATURES=False

# ===== RATE LIMITING =====
# Requests per day for unauthenticated users
RATE_LIMIT_REQUESTS_PER_DAY=1000

# ===== MOBILE APP CONFIGURATION (IF APPLICABLE) =====
# API keys for mobile app access
MOBILE_API_KEY=

# ===== VERSION & METADATA =====
APP_VERSION=1.0.0
APP_NAME=Pronunciation Trainer
APP_DESCRIPTION=Interactive pronunciation training system

# ===== NOTES FOR PRODUCTION DEPLOYMENT =====
# 1. NEVER commit this file with real values
# 2. NEVER share SECRET_KEY or credentials
# 3. Use Railway Secrets or AWS Secrets Manager for production
# 4. Rotate credentials every 90 days
# 5. Use strong passwords for DATABASE_URL
# 6. Enable SSL/TLS for database connections
# 7. Monitor and audit access logs regularly
